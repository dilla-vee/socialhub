# Supabase credentials (use SERVICE ROLE key only on the backend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin credentials
# Either provide a bcrypt hash or a plaintext admin password for local development.
# To use a plaintext password, set ADMIN_PASSWORD directly in .env.
# To use a bcrypt hash, generate one with:
#   node -e "import('bcryptjs').then(b => b.default.hash('yourPassword', 12).then(console.log))"
ADMIN_EMAIL=admin@socialhub.com
ADMIN_PASSWORD=admin
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here

# Secret used to sign JWT session tokens — use a long random string in production
JWT_SECRET=socialhub_super_secret_jwt_key_change_me
